# mcp-threatlocker — copy to .env and fill in real values

# ── ThreatLocker instance ─────────────────────────────────────────────────────
# Letter identifier for your portal (results in portalapi.<instance>.threatlocker.com)
THREATLOCKER_INSTANCE=h

# ── ThreatLocker API credentials ─────────────────────────────────────────────
# 64-character hex token from ThreatLocker portal → Settings > API Keys
THREATLOCKER_API_KEY=CHANGE_ME

# ── Logging (optional) ───────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal | silent  (default: info)
# LOG_LEVEL=info

# ── Override base URL (optional) ─────────────────────────────────────────────
# Leave blank to auto-derive from THREATLOCKER_INSTANCE above
# THREATLOCKER_BASE_URL=https://portalapi.h.threatlocker.com

# ── Write gate (optional) ─────────────────────────────────────────────────────
# Comma-separated list of write tool names that are permitted to execute.
# Use '*' to allow all write tools. Default (empty) = read-only mode (safest).
# Example (allow specific tools):
#   MCP_WRITE_ALLOWLIST=application_insert,computer_update_for_edit
# Example (allow all writes — use with caution):
#   MCP_WRITE_ALLOWLIST=*
# MCP_WRITE_ALLOWLIST=

# When 'true', every write tool execution emits a warn-level audit log entry.
# MCP_REQUIRE_CONFIRM=false
